# ==============================================================================
# Sentinel AI Local Environment Configuration
# ==============================================================================

ENV=development
DEBUG=true
PROJECT_NAME="Sentinel AI"
API_V1_STR=/api/v1

# Relational Database (pointing to postgres container exposed port)
DB__URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/sentinel
DB__POOL_SIZE=20

# Cache Database (pointing to redis container exposed port)
CACHE__URL=redis://localhost:6379/0
CACHE__TIMEOUT=2.0

# Vector Database (pointing to qdrant container exposed port)
VECTOR__URL=http://localhost:6333
VECTOR__API_KEY=

# Local LLM Service (pointing to ollama container exposed port)
LLM__API_BASE=http://localhost:11434
LLM__PRIMARY_MODEL=gemma2:9b
LLM__SECONDARY_MODEL=qwen2.5-coder:7b
LLM__EMBEDDING_MODEL=nomic-embed-text

# Object Storage (pointing to minio container exposed port)
STORAGE__ENDPOINT=localhost:9000
STORAGE__ACCESS_KEY=miniouser
STORAGE__SECRET_KEY=miniopassword
STORAGE__SECURE=false

# Telemetry Configuration
TELEMETRY__ENABLED=false
TELEMETRY__OTLP_ENDPOINT=http://localhost:4317
TELEMETRY__SERVICE_NAME=sentinel-ai-backend

# Security Configuration
SECURITY__SECRET_KEY=dev_secret_key_for_sentinel_ai_local_run
SECURITY__TOKEN_EXPIRY_MINUTES=60
