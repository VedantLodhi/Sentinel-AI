# ==============================================================================
# Sentinel AI Environment Configuration Template (Composed Nested Structure)
# ==============================================================================

ENV=development
DEBUG=true
PROJECT_NAME="Sentinel AI"
API_V1_STR=/api/v1

# Relational Database (PostgreSQL via Docker)
DB__URL=postgresql+asyncpg://postgres:postgrespassword@db:5432/sentinel
DB__POOL_SIZE=20

# Cache Database (Redis via Docker)
CACHE__URL=redis://redis:6379/0
CACHE__TIMEOUT=2.0

# Vector Database (Qdrant via Docker)
VECTOR__URL=http://qdrant:6333
VECTOR__API_KEY=

# Local LLM Service (Ollama via Docker)
LLM__API_BASE=http://ollama:11434
LLM__PRIMARY_MODEL=gemma2:9b
LLM__SECONDARY_MODEL=qwen2.5-coder:7b
LLM__EMBEDDING_MODEL=nomic-embed-text

# Object Storage (MinIO via Docker)
STORAGE__ENDPOINT=minio:9000
STORAGE__ACCESS_KEY=miniouser
STORAGE__SECRET_KEY=miniopassword
STORAGE__SECURE=false

# Telemetry Configuration (OpenTelemetry / Prometheus)
TELEMETRY__ENABLED=false
TELEMETRY__OTLP_ENDPOINT=http://otel-collector:4317
TELEMETRY__SERVICE_NAME=sentinel-ai-backend

# Security Configuration
SECURITY__SECRET_KEY=dev_secret_key_change_me_in_production_32_bytes_long
SECURITY__TOKEN_EXPIRY_MINUTES=60
